<section
  id="{{ table.dom_id }}"
  class="tab-panel{% if is_active %} is-active{% endif %}"
  role="tabpanel"
  aria-labelledby="trigger-{{ table.dom_id }}"
  {% if not is_active %}hidden{% endif %}
>
  <h2>{{ table.name }}</h2>
  <div class="sankey-container">
    {{ table.sankey_html | safe }}
  </div>
  <div class="table-container">
    {{ table.html | safe }}
  </div>
</section>
